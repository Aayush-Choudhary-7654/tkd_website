MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=active_taekwondo

ADMIN_EMAIL=admin@example.com
# Escape dollar signs in bcrypt hashes when pasting into .env.local, for example:
# ADMIN_PASSWORD_HASH=\$2b\$12\$replace_with_hash
ADMIN_PASSWORD_HASH=
AUTH_SECRET=replace-with-a-long-random-secret

CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
CLOUDINARY_UPLOAD_FOLDER=active-taekwondo/gallery
