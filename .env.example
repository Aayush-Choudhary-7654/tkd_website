MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_DB=active_taekwondo

# Generate with: node -e "console.log(require('bcryptjs').hashSync('change-this-password', 12))"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$12$replace-with-bcrypt-hash-for-your-local-admin-password
# Generate with: node -e "console.log(require('crypto').randomUUID())"
AUTH_SECRET=replace-with-a-long-random-secret

NEXT_PUBLIC_SITE_PHONE=+91 00000 00000
NEXT_PUBLIC_SITE_WHATSAPP=910000000000
NEXT_PUBLIC_SITE_ADDRESS=Durg, Chhattisgarh
NEXT_PUBLIC_SITE_MAP_URL=https://maps.google.com/?q=Durg%20Chhattisgarh
NEXT_PUBLIC_SITE_INSTAGRAM=https://instagram.com/
NEXT_PUBLIC_SITE_FACEBOOK=https://facebook.com/
