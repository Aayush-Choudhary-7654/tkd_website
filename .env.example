MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=active_taekwondo

ADMIN_EMAIL=admin@example.com
# Escape dollar signs in bcrypt hashes when pasting into .env.local, for example:
# ADMIN_PASSWORD_HASH=\$2b\$12\$replace_with_hash
ADMIN_PASSWORD_HASH=
AUTH_SECRET=replace-with-a-long-random-secret

# Optional comma-separated list for extra trusted dashboard origins.
# Usually not needed when the site runs on one domain.
ALLOWED_ORIGINS=

# Optional WhatsApp notifications for new inquiries and student bookings.
# Use Meta WhatsApp Business Cloud API credentials. Keep the access token private.
WHATSAPP_NOTIFICATIONS_ENABLED=true
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Recipient mobile number with country code, digits only or with + is okay.
WHATSAPP_NOTIFY_TO=
# Optional approved template with one body variable for production notifications.
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en_US

# Optional email notifications for new inquiries, free trials, and student joinings.
# Uses Resend API without extra npm packages. Keep the API key private.
EMAIL_NOTIFICATIONS_ENABLED=true
RESEND_API_KEY=
# Example: Active Taekwondo <notifications@yourdomain.com>
EMAIL_FROM=
# Comma-separated recipient list.
EMAIL_NOTIFY_TO=
# Optional reply-to and subject prefix.
EMAIL_REPLY_TO=
EMAIL_SUBJECT_PREFIX=ACTIVE TAEKWONDO
